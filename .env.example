# Heard - Environment Variables
# Copy this file to .env and fill in your keys.
#
# DATABASE_URL and AUTH_SECRET are environment-specific and go in:
#   .env.development  (loaded by `make dev`)
#   .env.production   (loaded by `make start`)
# See .env.development.example and .env.production.example.
#
# IMPORTANT: If your Supabase password contains special characters,
# URL-encode them in DATABASE_URL (# → %23, ! → %21, , → %2C)
# and wrap the value in single quotes.

# Anthropic API Key (required — get from team or https://console.anthropic.com)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Cicero API Key (required for district matching)
CICERO_API_KEY=your-cicero-api-key

# ElevenLabs API Key (required for voice features — STT and TTS)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Optional: Tavily API Key (for enhanced web search)
# TAVILY_API_KEY=your-tavily-api-key

# Optional: Jina API Key (for web fetch)
# JINA_API_KEY=your-jina-api-key

# Optional: ElevenLabs Voice ID for TTS (defaults to "George" voice)
# ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
