# Heard — Production Environment Overrides
# Copy this file to .env.production and fill in real values.
# This file is loaded by `make start` and overrides values from .env.

# Production PostgreSQL database (Supabase recommended, any Postgres works)
# NOTE: URL-encode special characters in the password (# → %23, ! → %21, , → %2C)
DATABASE_URL='postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROD-PROJECT-REF].supabase.co:5432/postgres'

# Auth secrets — generate with: openssl rand -hex 32
# AUTH_SECRET and BETTER_AUTH_SECRET MUST be identical.
# USE STRONG, UNIQUE VALUES IN PRODUCTION — DO NOT REUSE DEV SECRETS.
AUTH_SECRET=change-me-generate-a-random-32-char-secret
BETTER_AUTH_SECRET=change-me-generate-a-random-32-char-secret
